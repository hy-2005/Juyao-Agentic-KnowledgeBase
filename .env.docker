# ============================================================================
# Docker Compose 环境变量
# ============================================================================
# 复制为 .env 后修改: cp .env.docker .env
# docker compose 会自动读取 .env 中的变量
#
# 警告: 以下密码仅用于本地开发，生产环境务必更换强密码！

# MySQL root 密码
MYSQL_ROOT_PASSWORD=123456

# Neo4j 认证 (格式: username/password)
NEO4J_AUTH=neo4j/12345678
