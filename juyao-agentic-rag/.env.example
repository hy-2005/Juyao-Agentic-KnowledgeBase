# juyao-agentic-rag 环境变量模板
# 复制为 .env 后填入真实值：cp .env.example .env

# --- 必填（使用百炼 / DashScope 能力时）---
DASHSCOPE_API_KEY=

# --- 对话 LLM（可与百炼 Key 分离，例如 MiniMax）---
# LLM_API_KEY=

# --- 可选密钥 ---
OPENAI_API_KEY=
QDRANT_API_KEY=
NEO4J_PASSWORD=
RAG_INGEST_INTERNAL_TOKEN=

# --- 常用覆盖（不配则使用 config/default.toml）---
# EMBED_PROVIDER=ollama          # ollama | dashscope
# EMBED_MODEL=text-embedding-v4
# EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# RERANK_PROVIDER=dashscope
# DASHSCOPE_RERANK_MODEL=qwen3-rerank
# DASHSCOPE_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# GEN_MODEL=qwen3.6-35b-a3b
# QDRANT_URL=http://localhost:6333
# ELASTICSEARCH_URL=http://localhost:9201
# REDIS_URL=redis://localhost:6379/0
# NEO4J_URI=bolt://localhost:7687
# KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
# RAG_API_HOST=0.0.0.0
# RAG_API_PORT=8000
